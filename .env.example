# Copier vers .env.local (ne pas committer les secrets)

NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Serveur uniquement (dépôt profils, parse CV)
SUPABASE_SERVICE_ROLE_KEY=

# Optionnel — salage des hash IP (dépôt + parse-cv)
# DEPOT_IP_SALT=
# VOTE_IP_SALT=

# Affinda — extraction des champs depuis le CV (/api/parse-cv, page /depot)
# Clé : Affinda → Settings / API (sans guillemets dans Vercel)
AFFINDA_API_KEY=
# Région = même logique que l’URL du site Affinda (sinon 401) :
#   app.eu1.affinda.com  → AFFINDA_API_BASE=https://api.eu1.affinda.com
#   app.us1.affinda.com  → AFFINDA_API_BASE=https://api.us1.affinda.com
#   app.affinda.com      → AFFINDA_API_BASE=https://api.affinda.com
# Optionnel : si absent, défaut EU (api.eu1) — mauvais défaut = 401 même avec une bonne clé
# AFFINDA_API_BASE=https://api.eu1.affinda.com

# Taille max fichier pour parse-cv (octets), défaut 5242880
# AFFINDA_PARSE_MAX_BYTES=5242880
