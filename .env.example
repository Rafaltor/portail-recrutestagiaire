# Copier vers .env.local (ne pas committer les secrets)

NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Serveur uniquement (dépôt profils, parse CV)
SUPABASE_SERVICE_ROLE_KEY=

# Optionnel — salage des hash IP (dépôt + parse-cv)
# DEPOT_IP_SALT=
# VOTE_IP_SALT=

# Affinda — extraction des champs depuis le CV (/api/parse-cv, page /depot)
AFFINDA_API_KEY=
# Optionnel — défaut https://api.eu1.affinda.com
# AFFINDA_API_BASE=https://api.eu1.affinda.com

# Taille max fichier pour parse-cv (octets), défaut 5242880
# AFFINDA_PARSE_MAX_BYTES=5242880
